# All secrets live in .env.local (gitignored). This file lists the keys
# every service reads, with placeholder values. Copy to .env for local dev.

# --- Auth ---------------------------------------------------------
JWT_SECRET=change-me-to-at-least-32-chars-of-random-bytes
JWT_EXPIRES_IN=3600

# --- LLM providers (llm-gateway) ---------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Route each logical model to a backend. Comma-separated, first-available wins.
LLM_ROUTE_TRIAGE=claude-haiku-4-5-20251001,gpt-4o-mini
LLM_ROUTE_EXTRACTOR=claude-sonnet-4-6,gpt-4o
LLM_ROUTE_VERIFIER=claude-haiku-4-5-20251001

# --- Guardrails --------------------------------------------------
GUARD_DAILY_ORG_LIMIT_USD=25
GUARD_RATE_LIMIT_RPM=60

# --- Infrastructure ----------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5675
REDIS_URL=redis://localhost:6382
DATABASE_URL=postgres://lcm:lcm@localhost:5442/lcm

# --- MinIO ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_ACCESS_KEY=lcm
MINIO_SECRET_KEY=lcm-minio-secret
MINIO_BUCKET=lcm-documents
